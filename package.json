{
  "name": "turno-ya",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:types": "pnpm --filter @turno-ya/types build",
    "dev": "pnpm build:types && pnpm --parallel -r dev",
    "build": "pnpm build:types && pnpm -r build",
    "dev:api": "pnpm build:types && pnpm --filter @turno-ya/api dev",
    "dev:web": "pnpm --filter @turno-ya/web dev",
    "build:api": "pnpm build:types && pnpm --filter @turno-ya/api build",
    "build:web": "pnpm --filter @turno-ya/web build"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "bcrypt"
    ]
  }
}
